# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=railway_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── ML Service ───────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── Allocation Scheduler ──────────────────────────────────────────────────────
# Cron expression: every 15 minutes
ALLOCATION_CRON=*/15 * * * *
